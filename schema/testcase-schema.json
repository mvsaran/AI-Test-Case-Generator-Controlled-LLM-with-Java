{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/testcase-schema.json",
  "title": "AI Test Case Generator Schema",
  "description": "Schema for validating AI-generated test cases",
  "type": "object",
  "required": ["feature_name", "requirement_summary", "test_scenarios"],
  "properties": {
    "feature_name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the feature being tested"
    },
    "requirement_summary": {
      "type": "string",
      "minLength": 10,
      "description": "Short summary of the requirement"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "List of assumptions made during test case design"
    },
    "test_scenarios": {
      "type": "array",
      "minItems": 3,
      "description": "List of test scenarios generated by LLM",
      "items": {
        "type": "object",
        "required": [
          "test_case_id",
          "title",
          "objective",
          "preconditions",
          "test_steps",
          "test_data",
          "expected_result",
          "priority",
          "type",
          "negative",
          "automation_candidate"
        ],
        "properties": {
          "test_case_id": {
            "type": "string",
            "pattern": "^TC_[0-9]{3,}$",
            "description": "Unique test case ID like TC_001"
          },
          "title": {
            "type": "string",
            "minLength": 5,
            "description": "Descriptive title for the test case"
          },
          "objective": {
            "type": "string",
            "minLength": 10,
            "description": "What this test case aims to verify"
          },
          "preconditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Conditions that must be true before test execution"
          },
          "test_steps": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "string",
              "minLength": 5
            },
            "description": "Step-by-step actions to execute the test. Minimum 3 steps required."
          },
          "test_data": {
            "type": "object",
            "required": ["input", "notes"],
            "properties": {
              "input": {
                "type": "string",
                "description": "Test input data"
              },
              "notes": {
                "type": "string",
                "description": "Additional notes about the test data"
              }
            }
          },
          "expected_result": {
            "type": "string",
            "minLength": 10,
            "description": "Expected outcome after test execution"
          },
          "priority": {
            "type": "string",
            "enum": ["High", "Medium", "Low"],
            "description": "Priority of the test case"
          },
          "type": {
            "type": "string",
            "enum": ["Functional", "Negative", "Boundary", "Validation", "Error Handling"],
            "description": "Type/category of the test case"
          },
          "negative": {
            "type": "boolean",
            "description": "True if this is a negative test case"
          },
          "automation_candidate": {
            "type": "boolean",
            "description": "True if this test case is suitable for automation"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
